<?php
session_start();
require_once __DIR__ . '/../../Classes/Administrateur.php';
require_once __DIR__ . '/../../Classes/Database.php';

$admin = new Administrateur();
if (!$admin->isLoggedIn()) {
    header('Location: ../../login.php');
    exit;
}

$user = $admin->getLoggedInUser();
if (!$user) {
    session_destroy();
    header('Location: ../../login.php?error=session_expired');
    exit;
}

$user_id = $_GET['id'] ?? 0;
if (!$user_id) {
    header('Location: gestion_utilisateurs.php?error=id_manquant');
    exit;
}

$db = Database::getInstance()->getConnection();

// Récupérer l'utilisateur
$stmt = $db->prepare("
    SELECT u.*, 
           c.id_commercant as is_commercant,
           a.id_admin as is_admin,
           ag.id_agent as is_agent
    FROM utilisateurs u
    LEFT JOIN commercant c ON u.id_user = c.id_user
    LEFT JOIN admin a ON u.id_user = a.id_user
    LEFT JOIN agent_marche ag ON u.id_user = ag.id_user
    WHERE u.id_user = ?
");
$stmt->execute([$user_id]);
$utilisateur = $stmt->fetch();

if (!$utilisateur) {
    header('Location: gestion_utilisateurs.php?error=utilisateur_introuvable');
    exit;
}

$error = '';
$success = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $nom_complet = $_POST['nom_complet'] ?? '';
    $telephone = $_POST['telephone'] ?? '';
    $email = $_POST['email'] ?? '';
    $role = $_POST['role'] ?? '';
    $sexe = $_POST['sexe'] ?? 'Masculin';
    $nationalite = $_POST['nationalite'] ?? 'Congolaise';
    $adresse = $_POST['adresse'] ?? '';
    $date_naissance = $_POST['date_naissance'] ?? null;
    $mot_de_passe = $_POST['mot_de_passe'] ?? '';
    
    if (empty($nom_complet) || empty($role)) {
        $error = 'Veuillez remplir tous les champs obligatoires.';
    } else {
        try {
            $db->beginTransaction();
            
            // Mettre à jour l'utilisateur
            $sql = "UPDATE utilisateurs SET 
                        nom_complet = ?,
                        sexe = ?,
                        nationalite = ?,
                        date_naissance = ?,
                        adresse = ?,
                        telephone = ?,
                        email = ?";
            
            $params = [$nom_complet, $sexe, $nationalite, $date_naissance, $adresse, $telephone, $email];
            
            if (!empty($mot_de_passe)) {
                $sql .= ", mot_de_passe = ?";
                $params[] = password_hash($mot_de_passe, PASSWORD_DEFAULT);
            }
            
            $sql .= " WHERE id_user = ?";
            $params[] = $user_id;
            
            $stmt = $db->prepare($sql);
            $stmt->execute($params);
            
            // Mettre à jour le rôle
            // Supprimer les anciens rôles
            $stmt = $db->prepare("DELETE FROM commercant WHERE id_user = ?");
            $stmt->execute([$user_id]);
            $stmt = $db->prepare("DELETE FROM agent_marche WHERE id_user = ?");
            $stmt->execute([$user_id]);
            $stmt = $db->prepare("DELETE FROM admin WHERE id_user = ?");
            $stmt->execute([$user_id]);
            
            // Attribuer le nouveau rôle
            switch ($role) {
                case 'commercant':
                    $stmt = $db->prepare("INSERT INTO commercant (id_user) VALUES (?)");
                    $stmt->execute([$user_id]);
                    break;
                case 'agent':
                    $stmt = $db->prepare("INSERT INTO agent_marche (id_user) VALUES (?)");
                    $stmt->execute([$user_id]);
                    break;
                case 'admin':
                    $stmt = $db->prepare("INSERT INTO admin (id_user) VALUES (?)");
                    $stmt->execute([$user_id]);
                    break;
            }
            
            $db->commit();
            $success = "Utilisateur modifié avec succès !";
            
        } catch (Exception $e) {
            $db->rollBack();
            $error = 'Erreur: ' . $e->getMessage();
        }
    }
}

